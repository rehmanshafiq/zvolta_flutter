platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Simulator builds do not require signed pod frameworks; skipping avoids
      # CodeSign failures from iCloud xattrs in ~/Documents ("detritus not allowed").
      config.build_settings['CODE_SIGNING_ALLOWED[sdk=iphonesimulator*]'] = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED[sdk=iphonesimulator*]'] = 'NO'
      config.build_settings['CODE_SIGN_IDENTITY[sdk=iphonesimulator*]'] = ''
      config.build_settings['EXPANDED_CODE_SIGN_IDENTITY[sdk=iphonesimulator*]'] = ''
      config.build_settings['COPYFILE_DISABLE'] = 'YES'
    end
  end

  pods_root = File.join(File.dirname(File.realpath(__FILE__)), 'Pods')
  if File.directory?(pods_root)
    # Remove iCloud conflict duplicates (e.g. "pb_encode 2.c") that break Libtool linking.
    system('find', pods_root, '-name', '* 2.*', '-delete')
    system('find', pods_root, '-name', '* 2', '-depth', '-exec', 'rm', '-rf', '{}', '+')
  end

  # Keep iOS build artifacts outside iCloud-synced ~/Documents.
  project_root = File.expand_path('..', __FILE__)
  build_ios = File.join(project_root, 'build', 'ios')
  cache_ios = File.join(ENV['HOME'], 'Library', 'Caches', 'zvolta_flutter_ios_build', 'flutter_app_ios')
  system('mkdir', '-p', cache_ios)
  system('rm', '-rf', build_ios)
  system('ln', '-sf', cache_ios, build_ios)

  # Patch embed script: rsync copies iCloud xattrs that break codesign.
  Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', 'Pods-*', 'Pods-*-frameworks.sh')).each do |frameworks_sh|
    content = File.read(frameworks_sh)
    unless content.include?('strip_xattrs_for_codesign')
      strip_fn = <<~'SHELL'

        strip_xattrs_for_codesign() {
          export COPYFILE_DISABLE=1
          if [ -e "$1" ]; then
            local tmp="${1}.nostxattr"
            rm -rf "${tmp}"
            cp -R -X "$1" "${tmp}"
            rm -rf "$1"
            mv "${tmp}" "$1"
          fi
        }
      SHELL

      content = content.sub('code_sign_if_enabled() {', strip_fn + "code_sign_if_enabled() {")
      content = content.sub(
        'echo "Code Signing $1 with Identity ${EXPANDED_CODE_SIGN_IDENTITY_NAME}"',
        "strip_xattrs_for_codesign \"$1\"\n    echo \"Code Signing $1 with Identity ${EXPANDED_CODE_SIGN_IDENTITY_NAME}\"",
      )
    end

    unless content.include?('COPYFILE_DISABLE=1 cp -R -X')
      content = content.sub(
        /rsync --delete -av "\$\{RSYNC_PROTECT_TMP_FILES\[@\]\}" --links --filter "- CVS\/" --filter "- \.svn\/" --filter "- \.git\/" --filter "- \.hg\/" --filter "- Headers" --filter "- PrivateHeaders" --filter "- Modules" "\$\{source\}" "\$\{destination\}"/,
        'export COPYFILE_DISABLE=1
  echo "cp -R -X ${source} ${destination}"
  rm -rf "${destination}/$(basename "${source}")"
  cp -R -X "${source}" "${destination}/"',
      )
    end

    File.write(frameworks_sh, content)
  end
end
